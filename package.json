{
  "name": "plumbline-ui-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "start": "serve --single --listen tcp://0.0.0.0:${PORT:-3000} dist",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "check:assets": "node scripts/check-static-assets.mjs",
    "check:cta": "node scripts/check-cta-integrity.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "verify": "npm run lint && npm run build && npm audit --audit-level=moderate && npm run check:no-binary && npm run check:assets && npm run check:cta && npm run check:bundle",
    "check:no-binary": "node scripts/check-no-binary-files.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "serve": "^14.2.6",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.5.1"
  }
}
